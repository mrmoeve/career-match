:10000 {
    encode gzip zstd

    @pwa path /manifest.webmanifest /sw.js /icon-192.png /icon-512.png /apple-touch-icon.png /favicon.png /offline.html
    handle @pwa {
        root * /app/static
        file_server
        header Cache-Control "public, max-age=3600"
    }

    handle {
        reverse_proxy 127.0.0.1:8501
    }
}
